rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Requests
    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(requestId);
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(companyId);
    }

    // Offers
    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(offerId);
    }

    // Contracts
    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(contractId);
    }

    // Inspectors
    match /inspectors/{inspectorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(inspectorId);
    }

    // Stages
    match /stages/{stageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(stageId);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(notificationId);
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }
  }
}
